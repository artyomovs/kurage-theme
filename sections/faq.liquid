{% schema %}
{
  "name": "FAQ (Q&A Accordion)",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Got Questions? We’ve Got Answers"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Find answers to the most common questions and get the guidance you need to start designing and earning with ease."
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I create a design?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Simply enter a text description of your desired design, and our AI will generate a unique image for your T-shirt."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ (Accordion)",
      "category": "Custom",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" }
      ]
    }
  ]
}
{% endschema %}

<section class="faq-section">
  <div class="faq-container">
    <h2>{{ section.settings.heading }}</h2>
    <p class="faq-subheading">{{ section.settings.subheading }}</p>

    <div class="faq-items">
      {% for block in section.blocks %}
        <div class="faq-item" data-faq>
          <button class="faq-question" aria-expanded="false">
            <span>{{ block.settings.question }}</span>
            <span class="faq-toggle">+</span>
          </button>
          <div class="faq-answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.faq-section {
  padding: 4rem 2rem;
  background: #1C1C1C;
  color: #fff;
  text-align: left;
}
.faq-container {
  max-width: 800px;
  margin: 0 auto;
}
.faq-section h2 {
  font-size: 30px;
  font-weight: 200;
  margin-bottom: 1rem;
}
.faq-subheading {
  font-size: 18px;
  color: #B3B3B3;
  margin-bottom: 2rem;
}
.faq-items {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.faq-item {
  background: #2B2B2B;
  border-radius: 12px;
  overflow: hidden;
}
.faq-question {
  width: 100%;
  padding: 1.25rem;
  text-align: left;
  background: none;
  border: none;
  color: #fff;
  font-size: 20px;
  font-weight: 400;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: left;
}
.faq-toggle {
  font-size: 20px;
}
.faq-answer {
  display: none;
  padding: 0 1.25rem 1.25rem;
  color: #B3B3B3;
  font-size: 18px;
  font-weight: 200;
}
.faq-item.open .faq-answer {
  display: block;
}
.faq-item.open .faq-toggle {
  content: "-";
}
</style>

<script>
document.querySelectorAll('[data-faq]').forEach(item => {
  const button = item.querySelector('.faq-question');
  const answer = item.querySelector('.faq-answer');
  const toggle = item.querySelector('.faq-toggle');

  button.addEventListener('click', () => {
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('[data-faq]').forEach(i => i.classList.remove('open'));
    if (!isOpen) {
      item.classList.add('open');
      toggle.textContent = "–";
    } else {
      toggle.textContent = "+";
    }
  });
});
</script>
