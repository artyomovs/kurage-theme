{% schema %}
{
  "name": "Worldwide Shipping",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Worldwide Shipping, Fast Delivery"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Wherever you are, we’ll bring your favorite AI-designed T-shirts straight to your door. Enjoy global shipping with reliable, speedy delivery you can count on."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    }
  ],
  "presets": [
    {
      "name": "Worldwide Shipping",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section class="worldwide-shipping">
  <div class="shipping-container">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
    {% if section.settings.background_image != blank %}
      <img src="{{ section.settings.background_image | image_url: width: 1200 }}" alt="Worldwide Shipping">
    {% else %}
      <div class="shipping-placeholder">[ Add a world map image ]</div>
    {% endif %}

    <div class="idea-rotator">
      <input
        id="WorldIdeas-{{ section.id }}"
        class="idea-rotator__input"
        type="text"
        value=""
        readonly
        aria-live="polite"
        aria-label="T-shirt pritns ideas"
      >
    </div>
  </div>
</section>

<script>
  (function () {
    const input = document.getElementById('WorldIdeas-{{ section.id }}');
    if (!input) return;

    const ideas = [
      'Cyberpunk jellyfish with laser glow',
      'Retro Tokyo ramen mascot print',
      'Minimal mountain line art tee',
      'Neon cat DJ with headphones',
      'Astronaut surfing a pink wave',
      'Glitch skull with chrome roses',
      'Vintage racing tiger emblem',
      'Y2K butterfly and barcode collage',
      'Kawaii sushi gang illustration',
      'Street graffiti dragon lettering',
      'Abstract geometric sunset horizon',
      'Samurai mask in synthwave colors',
      'Lo-fi coffee shop night scene',
      'Futuristic koi fish motion blur',
      'Wild west cowboy in neon rain',
      'Space whale flying over city',
      'Graffiti smiley in 3D chrome',
      'Apocalyptic robot with flowers',
      'Old school tattoo eagle crest',
      'Japanese wave with digital noise'
    ];

    const used = new Set();
    const randomIdea = () => {
      if (used.size === ideas.length) used.clear();
      let pick = ideas[Math.floor(Math.random() * ideas.length)];
      while (used.has(pick)) {
        pick = ideas[Math.floor(Math.random() * ideas.length)];
      }
      used.add(pick);
      return pick;
    };

    const swapIdea = () => {
      input.classList.add('is-fading');
      window.setTimeout(() => {
        input.value = randomIdea();
        input.classList.remove('is-fading');
      }, 460);
    };

    input.value = randomIdea();
    window.setInterval(swapIdea, 2800);
  })();
</script>

<style>
.worldwide-shipping {
  background: #1C1C1C; /* dark background */
  padding: 4rem 2rem;
  text-align: center;
  color: #FFFFFF;
  border-radius: 16px;
  margin: 2rem auto;
  max-width: 1200px;
}

.worldwide-shipping h2 {
  font-size: 30px;
  font-weight: 100;
  margin-bottom: 1rem;
}

.worldwide-shipping p {
  font-size: 18px;
  line-height: 1.6;
  color: #B3B3B3;
  margin-bottom: 2.5rem;
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
}

.worldwide-shipping img {
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  display: block;
  border-radius: 12px;
}

.shipping-placeholder {
  width: 100%;
  height: 300px;
  background: #323232;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7A7A7A;
}

.idea-rotator {
  margin-top: 2rem;
  max-width: 58rem;
  margin-left: auto;
  margin-right: auto;
}

.idea-rotator__input {
  width: 100%;
  min-height: 5.2rem;
  border-radius: 999px;
  border: 1px solid rgba(38, 220, 255, 0.35);
  background: linear-gradient(160deg, rgba(8, 16, 34, 0.92), rgba(16, 12, 36, 0.8));
  color: rgba(255, 255, 255, 0.94);
  font-size: 1.7rem;
  font-weight: 600;
  padding: 0.9rem 2rem;
  box-shadow: 0 0 16px rgba(38, 220, 255, 0.2);
  transition: opacity 0.45s ease, transform 0.45s ease;
}

.idea-rotator__input.is-fading {
  opacity: 0;
  transform: translateY(0.4rem);
}
</style>
