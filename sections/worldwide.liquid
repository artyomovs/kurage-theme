{% schema %}
{
  "name": "Worldwide Shipping",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Worldwide Shipping, Fast Delivery"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Wherever you are, we’ll bring your favorite AI-designed T-shirts straight to your door. Enjoy global shipping with reliable, speedy delivery you can count on."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    }
  ],
  "presets": [
    {
      "name": "Worldwide Shipping",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section class="worldwide-shipping">
  <div class="shipping-container">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
    {% if section.settings.background_image != blank %}
      <img src="{{ section.settings.background_image | image_url: width: 1200 }}" alt="Worldwide Shipping">
    {% else %}
      <div class="shipping-placeholder">[ Add a world map image ]</div>
    {% endif %}
  </div>
</section>

<style>
.worldwide-shipping {
  padding: 0;
  text-align: center;
  color: #FFFFFF;
  margin: 0 auto;
  max-width: 100%;
}

.shipping-container {
  position: relative;
  overflow: hidden;
  max-width: 100%;
  margin: 0 auto;
  padding: 3.6rem 2rem 3rem;
  border-radius: 0;
  background: linear-gradient(155deg, rgba(7, 13, 34, 0.84), rgba(20, 12, 42, 0.7));
  border: none;
  box-shadow: none;
  animation: krgShipReveal 0.85s ease both;
}

.shipping-container::before {
  content: "";
  position: absolute;
  inset: -20% -15%;
  background: radial-gradient(circle at 20% 20%, rgba(38, 220, 255, 0.16), transparent 42%),
    radial-gradient(circle at 85% 75%, rgba(255, 77, 184, 0.14), transparent 45%);
  pointer-events: none;
  animation: krgShipGlow 10s ease-in-out infinite alternate;
}

.worldwide-shipping h2 {
  position: relative;
  z-index: 1;
  font-size: 30px;
  font-weight: 100;
  margin-bottom: 1rem;
}

.worldwide-shipping p {
  position: relative;
  z-index: 1;
  font-size: 18px;
  line-height: 1.6;
  color: #B3B3B3;
  margin-bottom: 2.5rem;
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
}

.worldwide-shipping img {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  display: block;
  border-radius: 12px;
  animation: krgMapFloat 8.5s ease-in-out infinite alternate;
}

.shipping-placeholder {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 300px;
  background: #323232;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7A7A7A;
}

@keyframes krgShipReveal {
  from {
    opacity: 0;
    transform: translateY(18px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes krgShipGlow {
  0% {
    transform: translate3d(-1.2%, -1.2%, 0) scale(1);
  }
  100% {
    transform: translate3d(1.2%, 1.2%, 0) scale(1.04);
  }
}

@keyframes krgMapFloat {
  0% {
    transform: translateY(0);
  }
  100% {
    transform: translateY(-7px);
  }
}

@media screen and (max-width: 749px) {
  .shipping-container {
    padding: 2.4rem 1.2rem 2rem;
    border-radius: 0;
  }

  .worldwide-shipping h2 {
    font-size: 25px;
  }

  .worldwide-shipping p {
    font-size: 16px;
  }
}
</style>
