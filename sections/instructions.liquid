{% schema %}
{
  "name": "3 Steps Section",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Create Your T-shirt in 3 steps"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "Let’s Earning"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Step Title",
          "default": "Create Your Design"
        },
        {
          "type": "textarea",
          "id": "step_text",
          "label": "Step Description",
          "default": "Enter a text description and let our AI generate a unique T-shirt design."
        },
        {
          "type": "image_picker",
          "id": "step_image",
          "label": "Step Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "3 Steps Section",
      "category": "Custom",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}

<section class="steps-section">
  <div class="steps-header">
    <h2>{{ section.settings.section_heading }}</h2>
    <a href="{{ section.settings.cta_link }}" class="btn btn-primary">{{ section.settings.cta_label }}</a>
  </div>

  <div class="steps-container">
    {% for block in section.blocks %}
      <div class="step-card">
        {% if block.settings.step_image != blank %}
          <img src="{{ block.settings.step_image | image_url: width: 400 }}" alt="{{ block.settings.step_title }}">
        {% else %}
          <div class="step-placeholder"></div>
        {% endif %}
        <div class="step-info">
          <span class="step-number">{{ block.settings.step_number }}</span>
          <h3>{{ block.settings.step_title }}</h3>
          <p>{{ block.settings.step_text }}</p>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<style>
.steps-section {
  padding: 4rem 2rem;
  background: #1C1C1C;
  color: #fff;
}

.steps-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2.5rem;
}

.steps-header h2 {
  font-size: 2rem;
  font-weight: 600;
  text-transform: none;
}

.steps-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.step-card {
  background: #2B2B2B;
  border-radius: 16px;
  padding: 2rem;
  text-align: left;
}

.step-card img {
  width: 100%;
  border-radius: 12px;
  margin-bottom: 1.5rem;
}

.step-placeholder {
  width: 100%;
  height: 180px;
  border-radius: 12px;
  background: #3A3A3A;
  margin-bottom: 1.5rem;
}

.step-info {
  display: flex;
  flex-direction: column;
}

.step-number {
  background: #444;
  padding: 0.4rem 0.75rem;
  border-radius: 6px;
  font-size: 0.9rem;
  font-weight: 600;
  margin-bottom: 0.75rem;
  display: inline-block;
}

.step-card h3 {
  font-size: 1.25rem;
  font-weight: 600;
  margin-bottom: 0.75rem;
}

.step-card p {
  color: #B3B3B3;
  line-height: 1.6;
  font-size: 1rem;
}

.btn-primary {
  background: #fff;
  color: #000;
  padding: 0.75rem 1.5rem;
  border-radius: 8px;
  font-weight: 600;
  text-decoration: none;
}

.btn-primary:hover {
  background: #F2F2F2;
}

@media (max-width: 900px) {
  .steps-container {
    grid-template-columns: 1fr;
  }
  .steps-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
}
</style>
