{% schema %}
{
  "name": "Hero Plugin (2 Columns)",
  "settings": [
    {
      "type": "header",
      "content": "Left Column"
    },
    {
      "type": "text",
      "id": "left_heading",
      "label": "Left heading",
      "default": "Create, design, and sell custom t-shirts"
    },
    {
      "type": "textarea",
      "id": "left_text",
      "label": "Left text",
      "default": "Create and sell custom print-on-demand t-shirts online with your designs, we'll print and ship to your customers wherever they are."
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left image"
    },
    {
      "type": "url",
      "id": "left_button_link",
      "label": "Left button link"
    },
    {
      "type": "text",
      "id": "left_button_label",
      "label": "Left button label",
      "default": "Create and Earn"
    },

    {
      "type": "header",
      "content": "Right Column"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right image"
    },
    {
      "type": "text",
      "id": "right_heading",
      "label": "Right heading",
      "default": "Explore T-shirts"
    },
    {
      "type": "textarea",
      "id": "right_text",
      "label": "Right text",
      "default": "Explore our collection of unique AI-generated T-shirts and pick your favorite. Choose, buy, and wear original prints created by people from around the world."
    },
    {
      "type": "url",
      "id": "right_button_link",
      "label": "Right button link"
    },
    {
      "type": "text",
      "id": "right_button_label",
      "label": "Right button label",
      "default": "See Catalog"
    }
  ],
  "presets": [
    {
      "name": "Hero Plugin (2 Columns)",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section class="hero-plugin">
  <div class="hero-container">

    <!-- LEFT COLUMN -->
    <div class="hero-col">
      <h1>{{ section.settings.left_heading }}</h1>
      <p>{{ section.settings.left_text }}</p>
      <a href="{{ section.settings.left_button_link }}" class="btn btn-primary">
        {{ section.settings.left_button_label }}
      </a>
      {% if section.settings.left_image != blank %}
        <img src="{{ section.settings.left_image | image_url: width: 600 }}" alt="Left Image">
      {% else %}
        <div class="hero-placeholder">[ Image Placeholder ]</div>
      {% endif %}
    </div>

    <!-- RIGHT COLUMN -->
    <div class="hero-col">
      {% if section.settings.right_image != blank %}
        <img src="{{ section.settings.right_image | image_url: width: 600 }}" alt="Right Image">
      {% else %}
        <div class="hero-placeholder">[ Image Placeholder ]</div>
      {% endif %}
      <h2>{{ section.settings.right_heading }}</h2>
      <p>{{ section.settings.right_text }}</p>
      <a href="{{ section.settings.right_button_link }}" class="btn btn-secondary">
        {{ section.settings.right_button_label }}
      </a>
    </div>

  </div>
</section>

<style>
.hero-plugin {
  width: 100%;
  margin: 0;
  padding: 4rem 2rem 0 2rem; /* bottom padding already 0 */
  color: #FFFFFF;
}

.hero-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  width: 100%;
  height: 100%;             /* fill the hero-plugin height */
}

.hero-col {
  padding: 4rem 2rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;  /* keep text aligned left */
  height: 100%;             /* ensure column stretches */
}

/* Left side */
.hero-col:first-child {
  background: #1C1C1C;   /* your darker shade */
}

/* Right side */
.hero-col:last-child {
  background: #2B2B2B;   /* your lighter shade */
}

.hero-col h1, .hero-col h2 {
  font-size: 3rem;   /* bigger text */
  font-weight: 600;
  margin-bottom: 1.25rem;
  text-transform: none;
}

.hero-col p {
  font-size: 2 rem;  /* slightly bigger text */
  line-height: 1.7;
  margin-bottom: 2rem; /* more space below text */
  color: #B3B3B3;
}

.hero-col img {
  max-width: 60%;      /* shrink images */
  margin-top: 2.5rem;  /* bigger space between text and image */
  border-radius: 12px;
}

.hero-placeholder {
  max-width: 60%;      /* match image size */
  height: 200px;       /* smaller placeholder */
  margin-top: 2.5rem;
}

.btn {
  display: inline-block;
  padding: 0.75rem 1.5rem;
  font-weight: 600;
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.2s;
}
.btn-primary {
  background: #FFFFFF;
  color: #000000;
}
.btn-primary:hover {
  background: #F2F2F2;
}
.btn-secondary {
  background: #FFFFFF;
  color: #000000;
  border: 2px solid #FFFFFF;
}
.btn-secondary:hover {
  background: #F2F2F2;
  color: #000000;
}
@media (max-width: 768px) {
  .hero-container {
    grid-template-columns: 1fr;
  }
  .hero-col {
    text-align: center;
  }
  .hero-col img, .hero-placeholder {
    margin-left: auto;
    margin-right: auto;
  }
}
</style>
