{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{%- style -%}
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
        @media screen and (max-width: 749px) {
     .section-{{ section.id }}-padding {
       padding-top: {{ section.settings.padding_top_mobile }}px;
       padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
     }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">
  <div
    class="section-{{ section.id }}-padding main-cta"
  >
    <div class="inner-cta page-width">
      <div class="heading">
        <h2 class="font-{{ section.settings.title_size }}">{{ section.settings.section_heading }}</h2>
        <div class="cta-idea-rotator">
          <input
            id="CtaIdeas-{{ section.id }}"
            class="cta-idea-rotator__input"
            type="text"
            value=""
            readonly
            aria-live="polite"
            aria-label="T-shirt pritns ideas"
          >
        </div>
      </div>
      <div class="cta-block">
        <a class="button button--primary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const input = document.getElementById('CtaIdeas-{{ section.id }}');
    if (!input) return;

    const ideas = [
      'Cyberpunk jellyfish with laser glow',
      'Retro Tokyo ramen mascot print',
      'Minimal mountain line art tee',
      'Neon cat DJ with headphones',
      'Astronaut surfing a pink wave',
      'Glitch skull with chrome roses',
      'Vintage racing tiger emblem',
      'Y2K butterfly and barcode collage',
      'Kawaii sushi gang illustration',
      'Street graffiti dragon lettering',
      'Abstract geometric sunset horizon',
      'Samurai mask in synthwave colors',
      'Lo-fi coffee shop night scene',
      'Futuristic koi fish motion blur',
      'Wild west cowboy in neon rain',
      'Space whale flying over city',
      'Graffiti smiley in 3D chrome',
      'Apocalyptic robot with flowers',
      'Old school tattoo eagle crest',
      'Japanese wave with digital noise'
    ];

    const used = new Set();
    const randomIdea = () => {
      if (used.size === ideas.length) used.clear();
      let pick = ideas[Math.floor(Math.random() * ideas.length)];
      while (used.has(pick)) {
        pick = ideas[Math.floor(Math.random() * ideas.length)];
      }
      used.add(pick);
      return pick;
    };

    const reveal = () => {
      input.classList.add('is-reveal');
      window.setTimeout(() => input.classList.remove('is-reveal'), 760);
    };

    const swapIdea = () => {
      input.classList.add('is-fading');
      window.setTimeout(() => {
        input.value = randomIdea();
        input.classList.remove('is-fading');
        reveal();
      }, 360);
    };

    input.value = randomIdea();
    reveal();
    window.setInterval(swapIdea, 2900);
  })();
</script>

{% schema %}
{
  "name": "Call To Action Section",
  "tag": "section",
  "class": "cta-section",
  "settings": [
    {
      "type": "richtext",
      "label": "Section Heading",
      "id": "section_heading"
    },
        {
      "type": "select",
      "id": "title_size",
      "label": "Heading Font Size",
      "options": [
        {
          "label": "Font-size 30",
          "value": "30"
        },
        {
          "label": "Font-size 32",
          "value": "32"
        },
        {
          "label": "Font-size 35",
          "value": "35"
        },
        {
          "label": "Font-size 40",
          "value": "40"
        }
      ],
      "default": "40"
    },
   {
        "type": "richtext",
        "label": "CTA Label",
        "id": "cta_label"
      },
        {
          "type": "url",
          "label": "CTA Link",
          "id": "cta_link"
        },
     {
    "type": "header",
    "content": "Color"
  },
    {
    "type": "color_scheme",
    "id": "color_scheme",
    "label": "t:sections.all.colors.label",
    "info": "t:sections.all.colors.has_cards_info",
    "default": "scheme-1"
  },
{
    "type": "header",
    "content": "Desktop Padding"
  },
  {
    "type": "range",
    "id": "padding_top",
    "min": 0,
    "max": 100,
    "step": 2,
    "unit": "px",
    "label": "t:sections.all.padding.padding_top",
    "default": 70
  },
  {
    "type": "range",
    "id": "padding_bottom",
    "min": 0,
    "max": 100,
    "step": 2,
    "unit": "px",
    "label": "t:sections.all.padding.padding_bottom",
    "default": 70
  },
    {
    "type": "header",
    "content": "Mobile Padding"
  },
  {
    "type": "range",
    "id": "padding_top_mobile",
    "min": 0,
    "max": 100,
    "step": 2,
    "unit": "px",
    "label": "t:sections.all.padding.padding_top",
    "default": 50
  },
  {
    "type": "range",
    "id": "padding_bottom_mobile",
    "min": 0,
    "max": 100,
    "step": 2,
    "unit": "px",
    "label": "t:sections.all.padding.padding_bottom",
    "default": 50
  }
  ],
  "presets": [
    {
      "name": "Call To Action Section"
    }
  ]
}
{% endschema %}
